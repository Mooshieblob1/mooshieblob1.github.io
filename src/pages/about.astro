---
import NoRainLayout from '../layouts/NoRainLayout.astro';
---

<NoRainLayout title="About - Mooshieblob" description="About MooshieBlob">
  <div
    class="min-h-screen bg-gray-900 px-5 pb-12 pt-20 text-gray-300 sm:px-8"
    style="will-change: opacity, filter, transform"
  >
    <a href="/" class="mx-auto mb-8 inline-flex rounded-lg p-2">
      <img
        src="/assets/images/bloblogo.webp"
        alt="logo"
        class="logo h-16 w-auto sm:h-20"
      />
    </a>

    <div class="mx-auto max-w-4xl text-center">
      <h1 class="mb-8 text-4xl font-bold text-yellow-400">About Me</h1>

      <p class="mb-6" style="text-wrap: balance">Hey there! I'm <span class="font-semibold text-yellow-300">MooshieBlob</span> — a developer who loves crafting beautiful web experiences, learning new tech, and making fun projects.</p>

      <p class="mb-6" style="text-wrap: balance">Whether it's working with <span class="text-yellow-300">frontend frameworks</span>, experimenting with <span class="text-yellow-300">AI tools</span>, or designing <span class="text-yellow-300">creative layouts</span>, I'm always excited to bring new ideas to life.</p>

      <p class="mb-6" style="text-wrap: balance">When I'm not coding, you might find me playing games, diving into anime, or exploring new tech innovations. Thanks for visiting my site!</p>

      <a
        href="/"
        class="mt-8 inline-block rounded bg-yellow-400 px-6 py-3 font-bold text-gray-900 transition hover:bg-yellow-300"
      >
        Back to Home
      </a>
    </div>
  </div>
</NoRainLayout>

<style>
  .logo {
    filter: drop-shadow(0 0 0.75rem rgba(255, 255, 0, 0.3));
  }
</style>

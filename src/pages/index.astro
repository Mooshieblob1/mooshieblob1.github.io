---
import BaseLayout from '../layouts/BaseLayout.astro';
import SplashScreen from '../components/SplashScreen.vue';
import SocialLinks from '../components/SocialLinks.vue';
---

<BaseLayout title="Mooshieblob" description="Am blob">
  <SplashScreen client:load />
  <div class="index-content">
    <div class="social-links flex">
      <img
        id="main-logo"
        src="/assets/images/bloblogo.webp"
        alt=""
        class="social-logo"
        transition:persist
      />
      <SocialLinks client:load />
    </div>
    <div class="back-row-toggle splat-toggle">
      <img
        id="bg_girl"
        src="/assets/images/raingirl.webp"
        alt="Background Image"
        class="h-4 w-auto md:h-6 lg:h-9"
      />
    </div>
  </div>
</BaseLayout>

<script>
  // Handle logo visibility for splash screen
  function initLogo() {
    const logo = document.getElementById('main-logo');
    if (!logo) return;
    
    if (sessionStorage.getItem('splash-shown')) {
      logo.style.opacity = '1';
    } else {
      logo.style.opacity = '0';
      document.addEventListener('splash-done', () => {
        logo.style.transition = 'opacity 0.3s ease';
        logo.style.opacity = '1';
      }, { once: true });
    }
  }
  
  initLogo();
  document.addEventListener('astro:after-swap', initLogo);
</script>

<style>
  .index-content {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
</style>

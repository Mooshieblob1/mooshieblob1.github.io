---
import { ViewTransitions } from 'astro:transitions';
import CursorFollower from '../components/CursorFollower.vue';
import '../styles/style.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Mooshieblob', description = 'Am blob' } = Astro.props;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body class="bg-[#02061a] text-white font-[Roboto,Arial,sans-serif]">
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-to-main">
      Skip to main content
    </a>

    <!-- Navbar -->
    <nav aria-label="Main navigation" class="fixed right-0 top-0 w-full bg-transparent p-4 z-50">
      <div class="container mx-auto flex items-center justify-end space-x-4">
        <div class="group relative">
          <a href="/images" class="hover-glow text-white transition duration-700 hover:text-yellow-400">
            Images
          </a>
        </div>
        <div class="group relative">
          <a href="/submit" class="hover-glow text-white transition duration-700 hover:text-yellow-400">
            Submit an Idea
          </a>
        </div>
        <div class="group relative">
          <a href="/about" class="hover-glow text-white transition duration-700 hover:text-yellow-400">
            About
          </a>
        </div>
      </div>
    </nav>

    <!-- Cursor Follower -->
    <CursorFollower client:load />

    <!-- Main Content -->
    <div class="layout-wrapper">
      <div class="page-wrapper">
        <main id="main-content" class="main-content" transition:animate="initial">
          <slot />
        </main>

        <!-- Footer -->
        <footer class="footer-container">
          <div class="footer-text">
            <span>&copy; 2024-{currentYear} Mooshieblob</span>
            <a id="ipv6" href="https://iplocation.io/ipv6-compatibility-checker?url=referer">
              <img
                src="https://iplocation.io/images/ipv6-non-validated.svg"
                alt="ipv6 ready"
                title="ipv6 ready"
                style="border: 0; padding: 0"
                width="36"
                height="18"
              />
            </a>
          </div>
        </footer>
      </div>
    </div>

    <script>
      import Lenis from 'lenis';

      function initLenis() {
        const lenis = new Lenis({
          autoRaf: true,
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });
        lenis.scrollTo(0, { immediate: true });
      }

      initLenis();

      document.addEventListener('astro:after-swap', () => {
        initLenis();
      });
    </script>

    <style is:global>
      /* Astro View Transitions: blur + zoom effect */
      @keyframes blur-zoom-in {
        from {
          opacity: 0;
          filter: blur(0.8rem);
          transform: scale(1.02) translateY(10px);
        }
        to {
          opacity: 1;
          filter: blur(0);
          transform: scale(1) translateY(0);
        }
      }

      @keyframes blur-zoom-out {
        from {
          opacity: 1;
          filter: blur(0);
          transform: scale(1) translateY(0);
        }
        to {
          opacity: 0;
          filter: blur(0.8rem);
          transform: scale(1.02) translateY(10px);
        }
      }

      ::view-transition-old(root) {
        animation: blur-zoom-out 0.4s ease forwards;
      }

      ::view-transition-new(root) {
        animation: blur-zoom-in 0.4s ease forwards;
      }

      .skip-to-main {
        position: absolute;
        top: -40px;
        left: 0;
        background: #fbc21b;
        color: #02061a;
        padding: 8px 16px;
        text-decoration: none;
        font-weight: bold;
        z-index: 10000;
        transition: top 0.2s;
      }

      .skip-to-main:focus {
        top: 0;
      }

      *:focus-visible {
        outline: 2px solid #fbc21b;
        outline-offset: 2px;
      }

      *:focus:not(:focus-visible) {
        outline: none;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
      }

      @keyframes glow {
        0% { text-shadow: 0 0 0 rgba(255, 255, 255, 0.5); }
        50% { text-shadow: 0 0 10px 5px rgba(255, 255, 255, 0.5); }
        100% { text-shadow: 0 0 0 rgba(255, 255, 255, 0.5); }
      }

      .hover-glow:hover {
        animation: glow 1s infinite;
      }

      button, .no-select {
        user-select: none;
      }

      input, textarea, p, span, h1, h2, h3, h4, h5, h6 {
        user-select: text;
      }

      .layout-wrapper,
      .page-wrapper {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .main-content {
        flex: 1;
      }

      .footer-container {
        background-color: transparent;
        text-align: center;
        padding: 20px;
        text-shadow: 0 0 8px black;
        position: relative !important;
      }

      .footer-text {
        display: flex;
        justify-content: center;
        align-items: center;
        color: rgb(174, 174, 174);
      }

      #ipv6 {
        height: 18px;
        margin-left: 10px;
      }
    </style>
  </body>
</html>
